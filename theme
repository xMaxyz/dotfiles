#!/bin/zsh
setopt extendedglob

#====================
#=====VARIABLES======
#====================
THEME=""
COMMON_DIR="$HOME/.dotfiles/common"
WORKING_DIR="$HOME/.dotfiles/working"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}"
RUN_INSTALL=false
RUN_THEME=false
RUN_WALLPAPER=false
VERBALIZE=""


#get parameters
while getopts "lvit:w:" opt; do
	case "$opt" in
		l) 
			ls -1 "$HOME/.dotfiles/themes/"
			exit 0
			;;

		v)
			VERBALIZE=true
			;;

		i)
			RUN_INSTALL=true
			;;
		
		t) 
			THEME="$OPTARG" 
			RUN_THEME=true
			RUN_WALLPAPER=true
			;;
		
		w) 
			WALLPAPER="$OPTARG"
			RUN_WALLPAPER=true
			;;
		
		\?)
			echo "Nutzung: $0 [-t theme_name] [-w wallpaper_name] [-l] [-i]"
			exit 1
			;;
	esac
done

THEME_DIR=$HOME/.dotfiles/themes/$THEME






#====================
#=====DEP CHECK======
#====================

#check if config dir exists
if [ ! -d "$CONFIG_DIR" ]; then
	if [ $VERBALIZE = true ]; then echo "Erstelle '$CONFIG_DIR'..."; fi
	mkdir -p "$CONFIG_DIR"
fi

#check if working dir exists
if [ ! -d "$WORKING_DIR" ]; then
	if [ $VERBALIZE = true ]; then echo "Erstelle '$WORKING_DIR'..."; fi
	mkdir -p "$WORKING_DIR"
fi





#====================
#=====FUNCTIONS======
#====================
callout() {
	message=""
	case "$1" in
		m) message="Bewege '$2' zu '$3'..." ;;
		l) message="Linke '$2' zu '$3'..." ;;
		r) message="Entferne '$2' in '$3'..." ;;
	esac
	echo "$message"
}

install_configs() {
	for content in "$COMMON_DIR"/*; do
		if [ -d "$content" ]; then
			local content_name="${content:t}"
			local dest="$CONFIG_DIR/$content_name"

			# Fall 1: Am Ziel existiert bereits ein Symlink (egal ob tot oder lebendig)
			if [ -L "$dest" ]; then
				# -h stellt in Zsh sicher, dass der Symlink selbst gelöscht/überschrieben wird, 
				# anstatt dem Link in den common-Ordner zu folgen
				rm -f "$dest"
				ln -sfn "$content" "$dest"
				if [ "$VERBALIZE" = true ]; then callout "l" "$dest" "$content"; fi

			# Fall 2: Am Ziel existiert ein echtes, bestehendes Verzeichnis (kein Link)
			elif [ -d "$dest" ]; then	
				mv "$dest" "$CONFIG_DIR/.$content_name.backup"
				if [ "$VERBALIZE" = true ]; then callout "m" "$content_name" ".$content_name.backup"; fi
				
				ln -sfn "$content" "$dest"
				if [ "$VERBALIZE" = true ]; then callout "l" "$dest" "$content"; fi

			# Fall 3: Am Ziel existiert eine normale Datei (z.B. falls mal eine Datei im common-Ordner liegt)
			elif [ -f "$dest" ]; then
				mv "$dest" "$CONFIG_DIR/.$content_name.backup"
				ln -sfn "$content" "$dest"
				if [ "$VERBALIZE" = true ]; then callout "l" "$dest" "$content"; fi

			# Fall 4: Das Ziel existiert noch gar nicht (frische Installation)
			else
				ln -sfn "$content" "$dest"
				if [ "$VERBALIZE" = true ]; then callout "l" "$dest" "$content"; fi
			fi
		fi
	done
	if [ -f "$COMMON_DIR/zshrc" ]; then
		ln -sfn "$COMMON_DIR/zshrc" "$HOME/.zshrc"
		if [ -z "$QML_IMPORT_PATH" ]; then
			echo "export QML_IMPORT_PATH='$WORKING_DIR/quickshell:$QML_IMPORT_PATH'" >> "$COMMON_DIR/zshrc"
		fi
		if [ $VERBALIZE = true ]; then callout "l" "$HOME/.zshrc" "$COMMON_DIR/zshrc"; fi
	fi
}


apply_theme() {
	#check if theme is specified
	if [ -z "$THEME" ]; then
		echo "Bitte ein Theme angeben!" >&2
		exit 1
	fi

	#check if theme exists
	if [[ ! -d "$THEME_DIR" ]]; then
		echo "Theme $THEME existiert nicht!" >&2
		exit 1
	fi

	#delete old symlinks
	for content in "$WORKING_DIR"/*~/current_theme(N); do #iterates through symlinks (@) and accepts an empty working dir (N)
		rm "$content"
		if [ $VERBALIZE ]; then callout "r" "${content:t}" "$WORKING_DIR"; fi
	done

	for content in "$THEME_DIR"/*(N); do #ignore quickshell
		if [ -d "$content" ]; then
			#get just the name of the dir, not entire path
			content_name="${content:t}"
			#link programm's theme dir to working dir 
			ln -sfn "$content" "$WORKING_DIR/$content_name"
			if [ $VERBALIZE ]; then callout "l" "$content_name" "$THEME"; fi

			#check if link is working, else print error in stderr
			if [ ! -d "$WORKING_DIR/$content_name" ]; then
				echo "Symlink für $content_dir konnte nicht erstellt werden!" >&2
			fi
		fi
	done

	echo "$THEME" > "$WORKING_DIR/current_theme"

	if [ -d "$THEME_DIR/dunst" ]; then dunstctl reload; fi
}

apply_wallpaper() {

	#check if wallpaper is empty
	if [[ -z "$WALLPAPER" ]]; then
		WALLPAPER="$THEME"
	fi

	wp_file="$HOME/Pictures/.wallpaper/$WALLPAPER"
	theme_wp_file="$HOME/Pictures/.wallpaper/$THEME"

	if [[ -f "$wp_file" ]]; then
		ln -sfn "$wp_file" "$HOME/Pictures/.wallpaper/wallpaper"
		if [ $VERBALIZE ]; then callout "l" "wallpaper" "${wp_file:t}"; fi
	elif [[ -n "$THEME" && -f "$theme_wp_file" ]]; then
		echo "Wallpaper '$WALLPAPER' existiert nicht. Fallback zu $THEME" >&2
		ln -sfn "$theme_wp_file" "$HOME/Pictures/.wallpaper/wallpaper"
	else
		echo "Kein gültiges Wallpaper gefunden und kein Fallback vorhanden. Abbruch." >&2
		exit 1
	fi

	pkill quickshell 1> /dev/null
	quickshell 1> /dev/null &
}

if [ "$RUN_INSTALL" = true ]; then install_configs; fi
if [ "$RUN_THEME" = true ]; then apply_theme; fi
if [ "$RUN_WALLPAPER" = true ]; then apply_wallpaper; fi
